include "menuDirective.dbd"
menu(menuApplyState) {
	choice(menuApplyStateIN,  "IN")
	choice(menuApplyStateOUT, "OUT")
}
recordtype(apply) {
	include "dbCommon.dbd" 
        field(VERS,DBF_DOUBLE) {
                prompt("Version Number")
                promptgroup(GUI_DISPLAY)
                special(SPC_NOMOD)
                interest(1)
        }
        field(STTE,DBF_MENU) {
                prompt("State")
                special(SPC_NOMOD)
                interest(1)
                menu(menuApplyState)
        }
	field(NPRC,DBF_LONG) {
		prompt("Num. Proc.")
                special(SPC_NOMOD)
		interest(1)
	}
	field(STFG,DBF_LONG) {
		prompt("Start Flag")
                special(SPC_NOMOD)
		interest(1)
	}
        field(MARK,DBF_SHORT) {
                prompt("Mark")
                special(SPC_NOMOD)
                interest(1)
        }
	field(LPRO,DBF_LONG) {
		prompt("Link Processing")
                special(SPC_NOMOD)
		interest(1)
	}
	field(TOP,DBF_LONG) {
		prompt("Top of tree")
                special(SPC_NOMOD)
		interest(1)
	}
	field(TOUT,DBF_FLOAT) {
		prompt("Timeout (sec)")
		interest(1)
	}
        field(RPVT,DBF_NOACCESS) {
		prompt("Record Private")
		special(SPC_NOMOD)
		interest(4)
		extra("void *rpvt")
        }
	field(VAL,DBF_LONG) {
		prompt("Return Error Code")
		interest(1)
	}
	field(DIR,DBF_MENU) {
		prompt("CAD Directive")
		promptgroup(GUI_OUTPUT)
		asl(ASL0)
		pp(TRUE)
                special(SPC_MOD)
		interest(1)
		menu(menuDirective)
	}
	field(CLID,DBF_LONG) {
		prompt("Client ID")
                special(SPC_MOD)
		interest(1)
	}
	field(MESS,DBF_STRING) {
		prompt("Message")
		interest(1)
		size(40)
	}
	field(OMSS,DBF_STRING) {
		prompt("Old Message")
		special(SPC_NOMOD)
		interest(1)
