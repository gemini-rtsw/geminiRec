include "menuSimulation.dbd" 
recordtype(sir) {
	include "dbCommon.dbd" 
        field(VERS,DBF_DOUBLE) {
                prompt("Version Number")
                promptgroup(GUI_DISPLAY)
                special(SPC_NOMOD)
                interest(1)
        }
	field(INP,DBF_INLINK) {
		prompt("Input Link")
		promptgroup(GUI_INPUTS)
		special(SPC_NOMOD)
		interest(1)
	}
	field(IMSS,DBF_STRING) {
		prompt("Message IN")
		interest(1)
		size(40)
	}
	field(FDSC,DBF_STRING) {
		prompt("Full Description")
		promptgroup(GUI_COMMON)
		interest(1)
		size(40)
	}
	field(FTVL,DBF_MENU) {
		prompt("Type of value")
		promptgroup(GUI_WAVE)
		special(SPC_NOMOD)
		interest(1)
		menu(menuFtype)
	}
	field(EGU,DBF_STRING) {
		prompt("Engineering Units")
		promptgroup(GUI_DISPLAY)
		interest(1)
		size(40)
	}
	field(VAL,DBF_NOACCESS) {
		prompt("Value OUT")
		special(SPC_DBADDR)
		pp(TRUE)
		interest(1)
		size(4)
		extra("void *val")
	}
	field(RVAL,DBF_NOACCESS) {
		prompt("Raw value IN")
		special(SPC_DBADDR)
		pp(TRUE)
		interest(1)
		size(4)
		extra("void *rval")
	}
	field(NELM,DBF_ULONG) {
		prompt("Number of Elements")
		promptgroup(GUI_COMPRESS)
		special(SPC_NOMOD)
		interest(1)
		initial("1")
	}
	field(NORD,DBF_ULONG) {
		prompt("Number elements read")
		special(SPC_NOMOD)
	}
	field(OMSS,DBF_STRING) {
		prompt("Message OUT")
		interest(1)
		size(40)
	}
	field(SNAM,DBF_STRING) {
		prompt("Subroutine Name")
		promptgroup(GUI_SUB)
		special(SPC_NOMOD)
		interest(1)
		size(40)
	}
	field(SADR,DBF_LONG) {
		prompt("Subroutine Address")
		special(SPC_NOMOD)
		interest(1)
	}
	field(PREC,DBF_SHORT) {
		prompt("Display Precision")
		promptgroup(GUI_DISPLAY)
		interest(1)
	}
	field(AVAL,DBF_NOACCESS) {
		prompt("Last Value Archived")
		special(SPC_NOMOD)
		interest(1)
		size(4)
		extra("void *aval")
	}
	field(MVAL,DBF_NOACCESS) {
		prompt("Last Value Monitored")
		special(SPC_NOMOD)
		interest(1)
		size(4)
		extra("void *mval")
	}
	field(AMSS,DBF_STRING) {
		prompt("Last Message Archived")
		interest(1)
		size(40)
	}
	field(MMSS,DBF_STRING) {
		prompt("Last Message Monitored")
		interest(1)
		size(40)
	}
	field(LALM,DBF_DOUBLE) {
		prompt("Last Value Alarmed")
		special(SPC_NOMOD)
		interest(3)
	}
	field(HIHI,DBF_FLOAT) {
		prompt("Hihi Alarm Limit")
		promptgroup(GUI_ALARMS)
		pp(TRUE)
		interest(1)
	}
	field(LOLO,DBF_FLOAT) {
		prompt("Lolo Alarm Limit")
		promptgroup(GUI_ALARMS)
		pp(TRUE)
		interest(1)
	}
	field(HIGH,DBF_FLOAT) {
		prompt("High Alarm Limit")
		promptgroup(GUI_ALARMS)
		pp(TRUE)
		interest(1)
	}
	field(LOW,DBF_FLOAT) {
		prompt("Low Alarm Limit")
		promptgroup(GUI_ALARMS)
		pp(TRUE)
		interest(1)
	}
	field(BRSV,DBF_MENU) {
		prompt("Bad Sub Return Severity")
		promptgroup(GUI_SUB)
		pp(TRUE)
		interest(1)
		menu(menuAlarmSevr)
	}
	field(HHSV,DBF_MENU) {
		prompt("Hihi Severity")
		promptgroup(GUI_ALARMS)
		pp(TRUE)
		interest(1)
		menu(menuAlarmSevr)
	}
	field(LLSV,DBF_MENU) {
		prompt("Lolo Severity")
		promptgroup(GUI_ALARMS)
		pp(TRUE)
		interest(1)
		menu(menuAlarmSevr)
	}
	field(HSV,DBF_MENU) {
		prompt("High Severity")
		promptgroup(GUI_ALARMS)
		pp(TRUE)
		interest(1)
		menu(menuAlarmSevr)
	}
	field(LSV,DBF_MENU) {
		prompt("Low Severity")
		promptgroup(GUI_ALARMS)
		pp(TRUE)
		interest(1)
		menu(menuAlarmSevr)
	}
	field(HYST,DBF_DOUBLE) {
		prompt("Alarm Deadband")
		promptgroup(GUI_ALARMS)
		interest(1)
	}
	field(ADEL,DBF_DOUBLE) {
		prompt("Archive Deadband")
		promptgroup(GUI_DISPLAY)
		interest(1)
	}
	field(MDEL,DBF_DOUBLE) {
		prompt("Monitor Deadband")
		promptgroup(GUI_DISPLAY)
		interest(1)
	}
	field(SIOL,DBF_INLINK) {
		prompt("Simulation Value Link")
		promptgroup(GUI_INPUTS)
		special(SPC_NOMOD)
		interest(1)
	}
	field(SVAL,DBF_NOACCESS) {
		prompt("Simulation Value")
		special(SPC_DBADDR)
		pp(TRUE)
		interest(1)
		size(4)
		extra("void *sval")
	}
	field(SIML,DBF_INLINK) {
		prompt("Simulation Mode Link")
		promptgroup(GUI_INPUTS)
		special(SPC_NOMOD)
		interest(1)
	}
	field(SIMM,DBF_MENU) {
		prompt("Simulation Mode")
		interest(1)
		menu(menuSimulation)
	}
	field(SIMS,DBF_MENU) {
		prompt("Sim Mode Alarm Severity")
		promptgroup(GUI_INPUTS)
		interest(2)
		menu(menuAlarmSevr)
	}
}
