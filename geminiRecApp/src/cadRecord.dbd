include "menuDirective.dbd"
include "menuSimulation.dbd"
menu(cadMFLG) {
	choice(cadMFLG_THREE_STATES, "THREE STATES")
	choice(cadMFLG_TWO_STATES,   "TWO STATES")
}
recordtype(cad) {
	include "dbCommon.dbd" 
	field(VERS,DBF_DOUBLE) {
		prompt("Version Number")
		promptgroup(GUI_DISPLAY)
		special(SPC_NOMOD)
		interest(1)
	}
	field(VAL,DBF_LONG) {
		prompt("Return Error Code")
		special(SPC_NOMOD)
		interest(1)
	}
	field(SNAM,DBF_STRING) {
		prompt("Subroutine Name")
		promptgroup(GUI_SUB)
		special(SPC_NOMOD)
		interest(1)
		size(40)
	}
	field(SADR,DBF_LONG) {
		prompt("Subroutine Address")
		special(SPC_NOMOD)
		interest(1)
	}
	field(INAM,DBF_STRING) {
		prompt("Init Routine Name")
		promptgroup(GUI_SUB)
		special(SPC_NOMOD)
		interest(1)
		size(40)
	}
	field(DIR,DBF_MENU) {
		prompt("CAD Directive")
		promptgroup(GUI_OUTPUT)
		asl(ASL0)
		pp(TRUE)
		interest(1)
		menu(menuDirective)
	}
	field(ODIR,DBF_MENU) {
		prompt("Output CAD Directive")
		promptgroup(GUI_OUTPUT)
		asl(ASL0)
		special(SPC_NOMOD)
		interest(2)
		menu(menuDirective)
